  layout(hovermode = "x unified",
    hoverlabel = list(
    align = "left",
    bgcolor = "white",
    font = list(size = 10)),
    xaxis = list(hoverformat = "<b> 12 Month-Ending Period: %B %Y </b>"),
    yaxis = list(title = "Deaths"),
